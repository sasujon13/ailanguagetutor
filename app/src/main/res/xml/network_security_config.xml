<?xml version="1.0" encoding="utf-8"?>
<!-- Release / production: HTTPS only; aligns with Play expectations and reduces cleartext risk flags. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
