# Copy to local.env.properties (gitignored) — DEBUG builds only.
# Release APK uses tunnel URLs baked in app/build.gradle.kts (ailt + ai.cheradip.com).

# --- Home AI (Intel Arc inference) via Cloudflare ---
HOME_AI_BASE_URL=https://ai.cheradip.com
# Emulator direct (no tunnel): http://10.0.2.2:8787

# --- App API (auth, billing, promo, cloud AI fallback) via Cloudflare ---
# server/cloud-api on your PC -> ailt.cheradip.com
API_BASE_URL=https://ailt.cheradip.com/api/ailt/
# Emulator direct (no tunnel): http://10.0.2.2:8790/api/ailt/

# Admin dev login (debug builds only)
ADMIN_SEED_PASSWORD=change-me
