# Copy to local.env.properties (gitignored) — DEBUG builds only.
# Release APK uses URLs baked in app/build.gradle.kts.

# --- Home AI (Intel Arc inference) via Cloudflare ---
HOME_AI_BASE_URL=https://ai.cheradip.com
# Emulator direct (no tunnel): http://10.0.2.2:8787

# --- App API (auth, billing, promo, language packs) on Linux ---
# Production URL (required): https://cheradip.com/ailt/api/
# Do NOT use ailt.cheradip.com — that host returns HTTP 530.
API_BASE_URL=https://cheradip.com/ailt/api/

# Where pack-builder syncs ZIPs (optional override)
# AILT_PACKS_DIR=D:/VSCode/cheradip/bcheradip/ailt_api/packs

# Admin dev login (debug builds only)
ADMIN_SEED_PASSWORD=change-me
