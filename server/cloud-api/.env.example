# XAMPP MySQL — copy to server/cloud-api/.env
HOST=0.0.0.0
PORT=8790

# Default XAMPP: user root, empty password, port 3306
DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3306/ailanguagetutor?charset=utf8mb4

ADMIN_SEED_EMAIL=sashafik.me@gmail.com
ADMIN_SEED_WHATSAPP=+8801722710298
ADMIN_SEED_PASSWORD=change-me

TRIAL_DAYS=7
DEV_LOG_OTP=true

PUBLIC_BASE_URL=http://localhost:8790/api/ailt
# Production: PUBLIC_BASE_URL=https://ailt.cheradip.com/api/ailt

# Optional cloud AI keys (fallback when home AI times out)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
GEMINI_MODEL=gemini-flash-latest
